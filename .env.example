# Copy this file to .env and fill it in. The .env file is NEVER committed (see .gitignore).

# Target origin (the API lives under ${BASE_URL}/api; the public index under ${BASE_URL}).
BASE_URL=https://iris.revelarautomation.com

# Reviewer's case token — required on every request via the X-Case-Token header.
CASE_TOKEN=

# Role passwords. Subject, Junior and Senior are non-sensitive credentials following the
# documented iris-<role>-2026 scheme (that the scheme is predictable is itself FINDING-008).
SUBJECT_PASSWORD=iris-subject-2026
JUNIOR_PASSWORD=iris-junior-2026
SENIOR_PASSWORD=iris-senior-2026

# Optional. Leave blank if you do not have it: tests that need Director are skipped
# gracefully (test.skip). DIRECTOR_PASSWORD is the FINDING-002 secret.
DIRECTOR_PASSWORD=
